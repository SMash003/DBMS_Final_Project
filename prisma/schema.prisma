generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CaseStatusType {
  OPEN
  UNDER_INVESTIGATION
  CLOSED
  COLD
}

enum RankLevel {
  CONSTABLE
  NAIK
  ASI
  SERGEANT
  SI
  INSPECTOR
  ASP
  ADDITIONAL_SP
  SP
  ADDITIONAL_DIG
  DIG
  ADDITIONAL_IGP
  IGP
}

enum OfficerDesignation {
  OC                 
  INVESTIGATION_OFFICER
  DUTY_OFFICER
  CIRCLE_OFFICER
  SDPO
  COMMANDANT
  COMMISSIONER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum VerdictType {
  PENDING
  GUILTY
  ACQUITTED
  DISMISSED
}

enum SentenceType {
  INCARCERATION
  PROBATION
  RESTITUTION
  COMMUNITY_SERVICE
  FINE
}

enum UserRole {
  ADMIN
  OFFICER
  CLERK
}

model Criminal {
  id          String   @id @default(uuid()) @db.Uuid()
  firstName   String   @db.VarChar(50)
  lastName    String   @db.VarChar(50)
  dateOfBirth DateTime @db.Date
  gender      Gender

  aliases     String?
  address     String?

  nidNumber   String   @unique @db.VarChar(17)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  criminalCases CriminalCase[]
  arrests       Arrest[]
  sentences     Sentence[]

  @@index([lastName])
  @@index([nidNumber])
}

model Station {
  id               String  @id @default(uuid()) @db.Uuid()
  stationName      String  @db.VarChar(100)
  locationAddress  String
  jurisdictionArea String? @db.VarChar(150)
  contactNumber    String? @db.VarChar(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officers Officer[]
  cases    Case[]
}

model Officer {
  id            String    @id @default(uuid()) @db.Uuid()
  badgeNumber   String    @unique @db.VarChar(20)
  firstName     String    @db.VarChar(50)
  lastName      String    @db.VarChar(50)
  gender        Gender
  rankLevel     RankLevel
  designation   OfficerDesignation?
  contactNumber String?   @db.VarChar(20)

  stationId String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  evidence Evidence[] @relation("OfficerEvidence")
  arrests  Arrest[]

  user User?

  @@index([stationId])
}

model Case {
  id               String    @id @default(uuid()) @db.Uuid()
  caseNumber       String    @unique @db.VarChar(20)
  title            String    @db.VarChar(150)
  description      String?
  dateReported     DateTime
  dateOfOccurrence DateTime?

  status CaseStatusType @default(OPEN)

  stationId String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  criminalCases CriminalCase[]
  evidence      Evidence[]
  arrests       Arrest[]
  courtCases    CourtCase[]
  victims       Victim[]
  witnesses     Witness[]

  @@index([caseNumber])
  @@index([stationId])
}

model Crime {
  id            String  @id @default(uuid()) @db.Uuid()
  crimeType     String  @unique @db.VarChar(100)
  severityLevel String  @db.VarChar(50)
  legalCodeRef  String? @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  criminalCases CriminalCase[]
}

model CriminalCase {
  id          String  @id @default(uuid()) @db.Uuid()
  criminalId  String  @db.Uuid()
  caseId      String  @db.Uuid()
  crimeId     String  @db.Uuid()
  roleInCrime String? @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  criminal Criminal @relation(fields: [criminalId], references: [id], onDelete: Cascade)
  case     Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  crime    Crime    @relation(fields: [crimeId], references: [id], onDelete: Cascade)

  @@unique([criminalId, caseId, crimeId])
  @@index([criminalId])
  @@index([caseId])
  @@index([crimeId])
}

model Evidence {
  id              String   @id @default(uuid()) @db.Uuid()
  evidenceCode    String   @unique @db.VarChar(30)
  description     String
  dateCollected   DateTime
  storageLocation String?  @db.VarChar(100)

  caseId               String @db.Uuid()
  collectedByOfficerId String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  collectedByOfficer Officer @relation("OfficerEvidence", fields: [collectedByOfficerId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([collectedByOfficerId])
}

model Arrest {
  id             String   @id @default(uuid()) @db.Uuid()
  arrestDateTime DateTime
  arrestLocation String?

  criminalId String @db.Uuid()
  caseId     String @db.Uuid()
  officerId  String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  criminal Criminal @relation(fields: [criminalId], references: [id], onDelete: Cascade)
  case     Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  officer  Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@index([criminalId])
  @@index([caseId])
  @@index([officerId])
}

model CourtCase {
  id          String    @id @default(uuid()) @db.Uuid()
  courtName   String    @db.VarChar(150)
  judgeName   String?   @db.VarChar(100)
  hearingDate DateTime?

  verdict VerdictType @default(PENDING)

  caseId String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  sentences Sentence[]

  @@index([caseId])
}

model Sentence {
  id             String       @id @default(uuid()) @db.Uuid()
  sentenceType   SentenceType
  durationMonths Int?
  fineAmount     Decimal?     @db.Decimal(15, 2)
  startDate      DateTime?    @db.Date

  courtCaseId String @db.Uuid()
  criminalId  String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courtCase CourtCase @relation(fields: [courtCaseId], references: [id], onDelete: Cascade)
  criminal  Criminal  @relation(fields: [criminalId], references: [id], onDelete: Cascade)

  @@index([courtCaseId])
  @@index([criminalId])
}

model Victim {
  id          String  @id @default(uuid()) @db.Uuid()
  firstName   String? @db.VarChar(50)
  lastName    String? @db.VarChar(50)
  gender      Gender
  contactInfo String?
  statement   String?

  caseId String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model Witness {
  id               String  @id @default(uuid()) @db.Uuid()
  firstName        String? @db.VarChar(50)
  lastName         String? @db.VarChar(50)
  gender           Gender
  contactInfo      String?
  statementSummary String?
  protectionStatus Boolean @default(false)

  caseId String @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model User {
  id           String  @id @default(uuid()) @db.Uuid()
  username     String  @unique @db.VarChar(50)
  passwordHash String  @db.VarChar(255)
  email        String? @unique @db.VarChar(100)

  role UserRole

  officerId String? @unique @db.Uuid()

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officer Officer? @relation(fields: [officerId], references: [id])

  @@index([officerId])
}
